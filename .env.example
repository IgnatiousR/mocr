# Copy this file to .env and update paths for your machine.

TRANSLATION_BACKEND=llama
TRANSLATION_MODEL_PATH=models/translation/gemma-2-2b-jpn-it-translate-Q4_K_M.gguf
TRANSLATION_BACKEND=sugoi
TRANSLATION_MODEL_PATH=models/translation/sugoi-v4-ja-en-ctranslate2
# Alternative Transformers backend:
# TRANSLATION_BACKEND=fugumt
# TRANSLATION_MODEL_PATH=models/translation/fugumt-ja-en
FONT_PATH=C:/Windows/Fonts/arial.ttf
REALESRGAN_MODEL_PATH=models/upscale/RealESRGAN_x4plus_anime_6B.pth
INPAINTER_BACKEND=opencv-telea
# Neural options: migan, anime-lama, big-lama
INPAINT_MODEL_PATH=
OUTPUT_DIR=outputs
PROCESSING_PROFILE=quality
DETECTOR_BACKEND=ctd
# New HF backends: bubble_seg, ctd_hf
# Quality profile can use 2 for low-resolution pages; fast profile should stay at 1.
PRE_UPSCALE_RATIO=1
PRE_DICT_PATH=
POST_DICT_PATH=
HARDWARE_ACCELERATION=cpu
LLAMA_THREADS=4
LLAMA_CONTEXT=2048
LLAMA_GPU_LAYERS=0
TRANSLATION_MODEL_REPO=entai2965/sugoi-v4-ja-en-ctranslate2
TRANSLATION_MODEL_REPO=webbigdata/gemma-2-2b-jpn-it-translate-gguf
# TRANSLATION_MODEL_REPO=staka/fugumt-ja-en
TRANSLATION_MODEL_FILE=gemma-2-2b-jpn-it-translate-Q4_K_M.gguf
REALESRGAN_MODEL_URL=https://github.com/xinntao/Real-ESRGAN/releases/download/v0.2.2.4/RealESRGAN_x4plus_anime_6B.pth
INPAINT_MODEL_URL=
